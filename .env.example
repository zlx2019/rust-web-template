# Copy this file to `.env` for local development; values are loaded on startup.

# Address the HTTP server binds to (host:port). Falls back to 0.0.0.0:3000.
BIND_ADDR=0.0.0.0:3000

# Log level filter (tracing_subscriber EnvFilter syntax).
# Examples: info | debug | "info,tower_http=debug"
RUST_LOG=info
